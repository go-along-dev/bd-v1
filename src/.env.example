# =============================================================================
# .env.example — Environment Variables Template
# =============================================================================
# See: system-design/00-architecture.md §6 "Environment Variables"
#
# Copy this file to .env and fill in real values.
# NEVER commit .env to git. Only .env.example is committed.
#
# In production, these come from GCP Secret Manager → Cloud Run env injection.
# See: system-design/09-infra.md §4 "Secret Manager"
# =============================================================================

# --- Supabase ---
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>
SUPABASE_DB_URL=postgresql+asyncpg://<user>:<password>@<db-host>:5432/postgres
SUPABASE_JWT_SECRET=<your-jwt-secret>

# --- MongoDB Atlas ---
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/goalong

# --- OSRM (self-hosted) ---
OSRM_BASE_URL=http://<osrm-vm-internal-ip>:5000

# --- Firebase Cloud Messaging ---
FCM_CREDENTIALS_JSON=./firebase-adminsdk.json

# --- Application ---
APP_ENV=development
APP_SECRET_KEY=<random-secret-for-session-middleware>
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# --- SQLAdmin Panel ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=<strong-admin-password>

# work by adolf.
